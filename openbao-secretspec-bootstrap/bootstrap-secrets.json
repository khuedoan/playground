{
  "mount": "apps",
  "secrets": [
    {
      "path": "payments/api",
      "fields": {
        "username": {
          "type": "literal",
          "value": "payments-service"
        },
        "password": {
          "type": "generate",
          "generator": "password",
          "length": 24
        },
        "endpoint": {
          "type": "env",
          "name": "PAYMENTS_ENDPOINT",
          "prompt": "Paste payments API endpoint: ",
          "secret": 0
        }
      }
    },
    {
      "path": "thirdparty/stripe",
      "fields": {
        "api_key": {
          "type": "env",
          "name": "STRIPE_API_KEY",
          "prompt": "Paste STRIPE_API_KEY: ",
          "secret": 1
        },
        "webhook_secret": {
          "type": "env",
          "name": "STRIPE_WEBHOOK_SECRET",
          "prompt": "Paste STRIPE_WEBHOOK_SECRET: ",
          "secret": 1
        },
        "rotation_id": {
          "type": "generate",
          "generator": "uuid"
        }
      }
    }
  ]
}
